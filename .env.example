# ─── Axevora Chat WebSocket URL ─────────────────────────────────────────────────
# Set this to your deployed Cloudflare Worker WebSocket URL after running:
# npx wrangler deploy
# The URL format will be: wss://axevora-chat.<your-subdomain>.workers.dev
VITE_CHAT_WS_URL=wss://axevora-chat.axevora.workers.dev

# ─── Firebase (already configured) ──────────────────────────────────────────────
# VITE_FIREBASE_API_KEY=...
# VITE_FIREBASE_AUTH_DOMAIN=...
# VITE_FIREBASE_PROJECT_ID=...
